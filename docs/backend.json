
{
  "entities": {
    "GeneratorLog": {
      "title": "Generator Maintenance Log",
      "description": "A record of maintenance performed on a home generator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "serviceType": { "type": "string", "enum": ["Oil Change", "Filter Replacement", "Battery Check", "Spark Plug Service", "General Inspection", "Repair"] },
        "hoursRun": { "type": "number", "description": "Total engine hours at time of service." },
        "performedBy": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "serviceType", "hoursRun"]
    },
    "ElectricalAudit": {
      "title": "Agency Electrical Audit",
      "description": "A comprehensive electrical safety audit (NEC/NFPA).",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["residential", "commercial"] },
        "overallScore": { "type": "number" },
        "status": { "type": "string" },
        "checkedItems": { "type": "object", "additionalProperties": { "type": "boolean" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "overallScore", "status"]
    },
    "DiagnosisRecord": {
      "title": "AI Diagnosis Record",
      "description": "A record of an AI-powered electrical issue diagnosis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "diagnosis": { "type": "string" },
        "urgency": { "type": "string" },
        "description": { "type": "string" },
        "findings": { "type": "array", "items": { "type": "object" } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/generatorLogs/{logId}": {
      "schema": "#/entities/GeneratorLog",
      "description": "Collection of maintenance logs for a specific user's generator."
    },
    "/users/{userId}/audits/{auditId}": {
      "schema": "#/entities/ElectricalAudit",
      "description": "Historical electrical audits performed for a user."
    },
    "/users/{userId}/diagnoses/{id}": {
      "schema": "#/entities/DiagnosisRecord",
      "description": "Historical AI diagnoses generated for a user."
    }
  }
}
