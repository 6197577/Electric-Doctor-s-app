
{
  "entities": {
    "Property": {
      "title": "Property Asset",
      "description": "A physical location or facility being tracked.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nickname": { "type": "string", "description": "e.g. 'Main Home', 'Downtown Office'" },
        "address": { "type": "string" },
        "propertyType": { "type": "string", "enum": ["Residential", "Commercial", "Industrial"] },
        "contactEmail": { "type": "string", "format": "email" },
        "contactPhone": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nickname", "address", "propertyType"]
    },
    "GeneratorLog": {
      "title": "Generator Maintenance Log",
      "description": "A record of maintenance performed on a specific property's generator.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "serviceType": { "type": "string", "enum": ["Oil Change", "Filter Replacement", "Battery Check", "Spark Plug Service", "General Inspection", "Repair"] },
        "hoursRun": { "type": "number" },
        "performedBy": { "type": "string" },
        "notes": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["date", "serviceType", "hoursRun"]
    },
    "ElectricalAudit": {
      "title": "Electrical Audit",
      "description": "A safety audit record tied to a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "type": { "type": "string", "enum": ["residential", "commercial"] },
        "overallScore": { "type": "number" },
        "status": { "type": "string" },
        "checkedItems": { "type": "object", "description": "Record of passed/failed checkpoints." },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DiagnosisRecord": {
      "title": "AI Diagnosis Record",
      "description": "An AI-powered diagnosis tied to a property.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "diagnosis": { "type": "string" },
        "urgency": { "type": "string" },
        "description": { "type": "string" },
        "findings": { "type": "array", "items": { "type": "object" } },
        "recommendations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["google.com"]
  },
  "firestore": {
    "/users/{userId}/properties/{propertyId}": {
      "schema": "#/entities/Property",
      "description": "Individual assets owned by the user."
    },
    "/users/{userId}/properties/{propertyId}/generatorLogs/{logId}": {
      "schema": "#/entities/GeneratorLog",
      "description": "Logs for a specific generator at a property."
    },
    "/users/{userId}/properties/{propertyId}/audits/{auditId}": {
      "schema": "#/entities/ElectricalAudit",
      "description": "Historical audits for a property."
    },
    "/users/{userId}/properties/{propertyId}/diagnoses/{id}": {
      "schema": "#/entities/DiagnosisRecord",
      "description": "AI diagnoses for a property."
    }
  }
}
